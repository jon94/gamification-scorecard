# Datadog API credentials
# Copy this file to .env and fill in your values
# Never commit .env to version control

# Required
DD_API_KEY=your_datadog_api_key_here
DD_APP_KEY=your_datadog_application_key_here

# Optional — defaults to datadoghq.com
# For AP1: DD_SITE=ap1.datadoghq.com
# For EU:  DD_SITE=datadoghq.eu
DD_SITE=datadoghq.com

# Human-readable org name shown in the header
DD_ORG_NAME=HKJC

# Admin PIN — required to unlock circle editing in the UI
# Change this to a secure PIN before sharing the URL publicly
ADMIN_PIN=1234

# Optional — filter users by domain (e.g. hkjc.org.hk) or comma-separated emails
# DD_USER_DOMAIN=hkjc.org.hk
# DD_USER_EMAILS=user1@hkjc.org.hk,user2@hkjc.org.hk
